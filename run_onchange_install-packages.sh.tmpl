{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

# Package list at time of render — changes here trigger re-run:
# pacman: {{ .packages.pacman | join " " }}
# aur: {{ .packages.aur | join " " }}

# Install official packages (--needed skips already-installed, idempotent)
PACMAN_PKGS=(
{{- range .packages.pacman }}
  {{ . }}
{{- end }}
)
sudo pacman -S --needed --noconfirm "${PACMAN_PKGS[@]}"

# Install AUR packages via paru (--needed is also idempotent)
AUR_PKGS=(
{{- range .packages.aur }}
  {{ . }}
{{- end }}
)
paru -S --needed --noconfirm "${AUR_PKGS[@]}"

{{ end -}}