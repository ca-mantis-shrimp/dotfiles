#!/usr/bin/env bash
set -euo pipefail

useradd -m -s /bin/bash agent

install -m 440 /dev/stdin /etc/sudoers.d/agent <<< 'agent ALL=(ALL) NOPASSWD: ALL'

install -d -o agent -g agent /home/agent/.config

install -m 755 -o agent -g agent /dev/stdin /home/agent/setup.sh << 'EOF'
#!/usr/bin/env bash
set -euo pipefail
curl -fsSL https://claude.ai/install.sh | bash -s stable
chezmoi apply --source /srv/chezmoi-source
EOF
