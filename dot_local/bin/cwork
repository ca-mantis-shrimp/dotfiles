#!/usr/bin/env bash
# cwork - launch a Claude Code workspace inside an mkosi container
# Usage: cwork <repo-path> [branch]
set -euo pipefail

REPO=${1:?Usage: cwork <repo-path> [branch]}
BRANCH=${2:-}
MKOSI_DIR="$HOME/.local/share/chezmoi/mkosi"
WORKTREES_DIR="$HOME/worktrees"

mkdir -p "$WORKTREES_DIR"

REPO_NAME=$(basename "$(realpath "$REPO")")
WORKTREE="$WORKTREES_DIR/$REPO_NAME"

if [[ -d "$WORKTREE" ]]; then
    echo "Reusing existing worktree at $WORKTREE"
else
    if [[ -n "$BRANCH" ]]; then
        git -C "$REPO" worktree add "$WORKTREE" "$BRANCH"
    else
        git -C "$REPO" worktree add "$WORKTREE"
    fi
fi

exec sudo CLAUDE_CODE_OAUTH_TOKEN="$(pass show llm/anthropic/pro)" mkosi \
    --directory="$MKOSI_DIR" \
    --runtime-tree="$WORKTREE":/workspace \
    shell -- bash -c 'cd /workspace && exec claude'
